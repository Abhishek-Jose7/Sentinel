ap: 8px;\n}\n\n/* Live Scanning Terminal HUD */\n.terminal-container {\n  background: var(--bg-terminal);\n  border: 1px solid var(--border-hud);\n  border-radius: var(--radius-lg);\n  overflow: hidden;\n  box-shadow: 0 12px 36px rgba(0, 0, 0, 0.5);\n}\n\n.terminal-header {\n  background: rgba(255, 255, 255, 0.02);\n  border-bottom: 1px solid var(--border-hud);\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: 12px 20px;\n}\n\n.terminal-buttons {\n  display: flex;\n  gap: 8px;\n}\n\n.term-btn {\n  width: 10px;\n  height: 10px;\n  border-radius: 50%;\n  display: inline-block;\n}\n\n.term-red { background: var(--error); opacity: 0.8; }\n.term-yellow { background: var(--warning); opacity: 0.8; }\n.term-green { background: var(--success); opacity: 0.8; }\n\n.terminal-title {\n  font-size: 11px;\n  color: var(--text-muted);\n  font-family: 'JetBrains Mono', monospace;\n}\n\n.terminal-status-glow {\n  width: 8px;\n  height: 8px;\n  background: var(--success);\n  border-radius: 50%;\n  box-shadow: 0 0 10px var(--success);\n}\n\n.terminal-body {\n  padding: 20px;\n  font-size: 12.5px;\n  font-family: 'JetBrains Mono', monospace;\n}\n\n.terminal-progress-row {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  margin-bottom: 16px;\n  border-bottom: 1px solid var(--border-hud);\n  padding-bottom: 16px;\n}\n\n.term-label {\n  color: var(--primary-hover);\n  font-weight: 600;\n}\n\n.term-progress-track {\n  flex-grow: 1;\n  background: rgba(255, 255, 255, 0.03);\n  height: 6px;\n  border-radius: 3px;\n  overflow: hidden;\n  border: 1px solid rgba(255, 255, 255, 0.05);\n}\n\n.term-progress-bar {\n  height: 100%;\n  background: linear-gradient(90deg, var(--primary), var(--accent-pro));\n  box-shadow: 0 0 10px var(--primary-glow);\n  transition: width 0.3s ease;\n  border-radius: 3px;\n}\n\n.term-percent {\n  color: var(--text-bright);\n  font-weight: 700;\n  width: 45px;\n  text-align: right;\n}\n\n.terminal-log-feed {\n  max-height: