x;\n  color: var(--text-muted);\n  font-weight: 600;\n  margin-top: 1px;\n}\n\n.score-status-badge {\n  font-size: 9px;\n  font-weight: 700;\n  letter-spacing: 0.08em;\n  margin-top: 18px;\n  padding: 4px 12px;\n  border-radius: 30px;\n  text-transform: uppercase;\n}\n\n.summary-hud-card {\n  display: flex;\n  flex-direction: column;\n  justify-content: space-between;\n}\n\n.summary-hud-card h3 {\n  font-size: 11px;\n  color: var(--text-muted);\n  letter-spacing: 0.10em;\n  margin-bottom: 14px;\n  text-transform: uppercase;\n}\n\n.summary-details h4 {\n  font-size: 18px;\n  font-weight: 700;\n  margin-bottom: 12px;\n  color: var(--text-bright);\n  letter-spacing: -0.01em;\n}\n\n.summary-content-text {\n  color: var(--text-normal);\n  font-size: 13.5px;\n  line-height: 1.7;\n}\n\n.hud-footer-quote {\n  font-size: 11.5px;\n  background: rgba(255, 255, 255, 0.02);\n  border-left: 3px solid var(--primary);\n  padding: 8px 16px;\n  margin-top: 20px;\n  color: var(--text-muted);\n  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;\n}\n\n.hud-footer-quote .accent-symbol {\n  color: var(--primary-hover);\n  font-weight: 700;\n}\n\n/* Dimensions Grid Styles */\n.dimensions-grid {\n  display: grid;\n  grid-template-columns: repeat(5, 1fr);\n  gap: 16px;\n}\n\n.dimension-card {\n  background: rgba(255, 255, 255, 0.02);\n  border: 1px solid var(--border-hud);\n  padding: 18px;\n  border-radius: var(--radius-md);\n  display: flex;\n  flex-direction: column;\n  transition: all var(--t-smooth);\n}\n\n.dimension-card:hover {\n  border-color: rgba(255, 255, 255, 0.1);\n  background: rgba(255, 255, 255, 0.04);\n  transform: translateY(-1px);\n}\n\n.dim-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 10px;\n}\n\n.dim-name {\n  font-size: 11px;\n  font-weight: 600;\n  text-transform: uppercase;\n  color: var(--text-muted);\n  letter-spacing: 0.05em;\n}\n\n.dim-score {\n  font-size: 13px;\n  font-weight: 700;\n  color: var(--text-bright);\n  font-family: 'JetBrains Mono', monospace;\n}\n\n.dim-bar-wrapper {\n  background: rgba(255, 255, 255, 0.04);\n  height: 4px;\n  margin-bottom: 12px;\n  border-radius: 2px;\n  overflow: hidden;\n}\n\n.dim-bar {\n  height: 100%;\n  border-radius: 2px;\n  transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1);\n}\n\n.dim-notes {\n  border-top: 1px dashed rgba(255, 255, 255, 0.06);\n  font-size: 10px;\n  font-family: 'JetBrains Mono', monospace;\n  margin-top: auto;\n  padding-top: 10px;\n}\n\n.note-hit {\n  color: var(--error);\n  margin-bottom: 4px;\n}\n\n.note-none {\n  color: var(--text-muted);\n  font-style: italic;\n}\n\n/* Two-Column split details layout */\n.details-split {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 24px;\n  margin-bottom: 32px;\n}\n\n.section-title-bar {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  margin-bottom: 16px;\n}\n\n.section-title-bar h3 {\n  margin-bottom: 0;\n}\n\n/* Risks List */\n.risks-list {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n}\n\n.risk-item {\n  background: rgba(255, 255, 255, 0.01);\n  border: 1px solid var(--border-hud);\n  border-radius: var(--radius-md);\n  padding: 16px;\n  transition: all var(--t-smooth);\n}\n\n.risk-item:hover {\n  border-color: rgba(255, 255, 255, 0.1);\n  background: rgba(255, 255, 255, 0.03);\n}\n\n.risk-item-header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  margin-bottom: 6px;\n}\n\n.risk-title {\n  font-size: 14px;\n  font-weight: 600;\n  color: var(--text-bright);\n}\n\n.risk-severity {\n  font-size: 9px;\n  font-weight: 700;\n  padding: 2px 6px;\n  text-transform: uppercase;\n  border-radius: 4px;\n}\n\n.risk-severity.critical {\n  background: var(--error-bg);\n  color: var(--error);\n  border: 1px solid rgba(244, 63, 94, 0.2);\n}\n\n.risk-severity.warning {\n  background: var(--warning-bg);\n  color: var(--warning);\n  border: 1px solid rgba(245, 158, 11, 0.2);\n}\n\n.risk-severity.info {\n  background: var(--info-bg);\n  color: var(--info);\n  border: 1px solid rgba(59, 130, 246, 0.2);\n}\n\n.risk-location {\n  color: var(--text-muted);\n  font-size: 10px;\n  font-family: 'JetBrains Mono', monospace;\n  margin-bottom: 8px;\n}\n\n.risk-why {\n  color: var(--text-normal);\n  font-size: 12.5px;\n  line-height: 1.5;\n}\n\n/* Memory panel details */\n.badge-memory {\n  background: var(--accent-pro-bg);\n  border: 1px solid rgba(236, 72, 153, 0.2);\n  color: var(--accent-pro);\n}\n\n.badge-memory.active {\n  background: var(--success-bg);\n  border: 1px solid rgba(16, 185, 129, 0.2);\n  color: var(--success);\n}\n\n.memories-panel {\n  background: rgba(255, 255, 255, 0.01);\n  border: 1px solid var(--border-hud);\n  border-radius: var(--radius-md);\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n  min-height: 220px;\n  padding: 20px;\n  position: relative;\n}\n\n.memories-panel.locked {\n  overflow: hidden;\n}\n\n.memories-panel.locked::after {\n  content: '';\n  background: linear-gradient(180deg, transparent 40%, var(--bg-darkest) 95%);\n  position: absolute;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  pointer-events: none;\n}\n\n.empty-state {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  text-align: center;\n  flex-grow: 1;\n  color: var(--text-muted);\n  padding: 32px 20px;\n}\n\n.empty-state p {\n  font-size: 12px;\n  line-height: 1.6;\n  max-width: 280px;\n  margin-top: 8px;\n}\n\n.memory-match-item {\n  border-bottom: 1px dashed var(--border-hud);\n  padding-bottom: 16px;\n}\n\n.memory-match-item:last-child {\n  border-bottom: none;\n  padding-bottom: 0;\n}\n\n.memory-match-header {\n  font-size: 11px;\n  font-weight: 600;\n  margin-bottom: 8px;\n  color: var(--accent-pro);\n  font-family: inherit;\n}\n\n.memory-match-text {\n  background: var(--accent-pro-bg);\n  border-left: 3px solid var(--accent-pro);\n  color: var(--text-normal);\n  font-size: 12px;\n  line-height: 1.5;\n  padding: 10px 14px;\n  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;\n}\n\n/* Long-Term Memory Ledger */\n.memories-log-card {\n  padding: 0;\n  overflow: hidden;\n  background: rgba(255, 255, 255, 0.01);\n  border-radius: var(--radius-lg);\n}\n\n.repo-memories-list {\n  display: flex;\n  flex-direction: column;\n}\n\n.repo-memories-list .memory-match-item {\n  border-bottom: 1px solid var(--border-hud);\n  padding: 20px 24px;\n}\n\n.repo-memories-list .memory-match-item:last-child {\n  border-bottom: none;\n}\n\n.repo-memories-list .empty-state {\n  padding: 40px;\n}\n\n/* Empty State / Welcome Interface */\n.empty-dashboard {\n  align-items: center;\n  justify-content: center;\n  text-align: center;\n  padding: 48px;\n}\n\n.empty-dashboard-content {\n  max-width: 480px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n}\n\n.empty-logo-hex {\n  font-size: 54px;\n  margin-bottom: 20px;\n  filter: drop-shadow(0 0 12px var(--primary-glow));\n}\n\n.empty-dashboard h2 {\n  font-size: 28px;\n  font-weight: 800;\n  margin-bottom: 10px;\n  letter-spacing: -0.01em;\n}\n\n.empty-dashboard p {\n  color: var(--text-normal);\n  font-size: 14px;\n  line-height: 1.6;\n  margin-bottom: 32px;\n}\n\n.import-card {\n  background: var(--bg-card);\n  border: 1px solid var(--border-hud);\n  border-radius: var(--radius-lg);\n  padding: 28px;\n  width: 100%;\n  text-align: left;\n  margin-bottom: 24px;\n  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);\n  backdrop-filter: blur(12px);\n}\n\n.import-card h3 {\n  font-size: 12px;\n  color: var(--text-bright);\n  text-transform: uppercase;\n  margin-bottom: 16px;\n  letter-spacing: 0.05em;\n}\n\n.import-form {\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n}\n\n.form-row-compact {\n  display: flex;\n  align-items: center;\n  background: var(--bg-darker);\n  border: 1px solid var(--border-hud);\n  padding: 4px 16px;\n  border-radius: var(--radius-md);\n  transition: all var(--t-smo