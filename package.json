{
  "name": "sentinel-mvp",
  "version": "2.0.0",
  "description": "Sentinel automated PR auditor and memory prediction engine MVP",
  "main": "src/index.ts",
  "scripts": {
    "build:assets": "node scripts/build_assets.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run build:assets && npm run typecheck",
    "dev": "wrangler dev",
    "deploy": "npm run build:assets && wrangler deploy",
    "db:migrate:local": "wrangler d1 execute sentinel-db --local --file=./db/schema.sql",
    "db:migrate:remote": "wrangler d1 execute sentinel-db --remote --file=./db/schema.sql"
  },
  "dependencies": {
    "@tsndr/cloudflare-worker-jwt": "^2.5.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240524.0",
    "typescript": "^5.4.5",
    "wrangler": "^4.103.0"
  }
}
