\n  width: 90%;\n  transform: scale(0.95);\n  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);\n}\n\n.modal-overlay.active .modal-box {\n  transform: scale(1);\n}\n\n.modal-close {\n  background: none;\n  border: none;\n  color: var(--text-muted);\n  cursor: pointer;\n  font-size: 24px;\n  position: absolute;\n  top: 16px;\n  right: 20px;\n  transition: color var(--t-smooth);\n}\n\n.modal-close:hover {\n  color: #fff;\n}\n\n.modal-icon {\n  font-size: 40px;\n  margin-bottom: 16px;\n  filter: drop-shadow(0 0 12px var(--accent-pro-glow));\n}\n\n.modal-box h2 {\n  font-size: 22px;\n  margin-bottom: 10px;\n}\n\n.modal-box p {\n  color: var(--text-normal);\n  font-size: 13px;\n  line-height: 1.6;\n  margin-bottom: 24px;\n}\n\n.modal-form {\n  text-align: left;\n}\n\n.form-field {\n  margin-bottom: 20px;\n}\n\n.form-field label {\n  color: var(--text-muted);\n  display: block;\n  font-size: 10px;\n  font-weight: 600;\n  margin-bottom: 8px;\n  letter-spacing: 0.05em;\n  text-transform: uppercase;\n}\n\n.form-field input {\n  background: var(--bg-darkest);\n  border: 1px solid var(--border-hud);\n  border-radius: var(--radius-md);\n  color: #fff;\n  font-family: 'JetBrains Mono', monospace;\n  font-size: 13px;\n  padding: 12px 16px;\n  outline: none;\n  width: 100%;\n  transition: all var(--t-smooth);\n}\n\n.form-field input:focus {\n  border-color: var(--accent-pro);\n  box-shadow: 0 0 0 2px var(--accent-pro-glow);\n}\n\n.form-error {\n  color: var(--error);\n  display: block;\n  font-size: 11px;\n  margin-top: 6px;\n}\n\n/* GitHub Login Overlay styling */\n.login-overlay {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 100vw;\n  height: 100vh;\n  background: var(--bg-darkest);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  z-index: 2000;\n}\n\n.login-box {\n  background: var(--bg-card);\n  border: 1px solid var(--border-hud);\n  padding: 48px;\n  max-width: 420px;\n  width: 90%;\n  text-align: center;\n  box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6);\n  backdrop-filter: blur(16px);\n  border-radius: var(--radius-lg);\n}\n\n.logo-shield {\n  font-size: 54px;\n  margin-bottom: 20px;\n  filter: drop-shadow(0 0 12px var(--primary-glow));\n}\n\n.login-box h2 {\n  margin-bottom: 10px;\n  font-size: 24px;\n  font-weight: 800;\n  letter-spacing: -0.01em;\n}\n\n.login-box p {\n  color: var(--text-normal);\n  font-size: 13.5px;\n  line-height: 1.6;\n  margin-bottom: 32px;\n}\n\n/* Media Query Adaptations */\n@media (max-width: 1200px) {\n  .app-container {\n    grid-template-columns: 240px 1fr;\n  }\n  .dashboard-main {\n    padding: 32px;\n  }\n  .hud-metrics-grid {\n    grid-template-columns: 1fr;\n  }\n  .dimensions-grid {\n    grid-template-columns: repeat(2, 1fr);\n  }\n  .details-split {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (max-width: 768px) {\n  .app-container {\n    display: block;\n  }\n  .sidebar {\n    height: auto;\n    position: static;\n    padding: 24px;\n    border-right: none;\n    border-bottom: 1px solid var(--border-hud);\n  }\n  .dashboard-main {\n    height: auto;\n    padding: 24px;\n  }\n  .hud-header {\n    flex-direction: column;\n    align-items: flex-start;\n    gap: 20px;\n  }\n  .hud-actions {\n    flex-wrap: wrap;\n    width: 100%;\n  }\n  .dimensions-grid {\n    grid-template-columns: 1fr;\n  }\n}\n\n/* --- FLAT DEVELOPER HUD MINIMALIST OVERRIDES (NO GRADIENTS, MONOSPACE FONTS, Stark Three-Pane Layout) --- */\n\n:root {\n  /* Stark flat technical theme variables */\n  --bg-darkest: #0A0A0C;      /* Flat deep black */\n  --bg-darker: #0F1015;       /* Solid dark gray */\n  --bg-hud: #14151C;          /* Panel background */\n  --bg-card: #14151C;         /* Flat card background */\n  --bg-terminal: #070709;     /* Console black */\n  \n  --border-hud: #24252D;      /* Solid slate border */\n  --border-hover: #404250;    /* Solid lighter border on hover */\n  --border-focus: #505260;\n  \n  --primary: #00FF66;         /* Flat terminal green */\n  --primary-hover: #33FF88;\n  --primary-glow: transparent;\n  --primary-bg: #14251C;      /* Very dark flat green */\n  \n  --accent-pro: #FFCC00;      /* Flat solid gold */\n  --accent-pro-glow: transparent;\n  --accent-pro-bg: #2C2612;   /* Very dark flat gold */\n  \n  --success: #00FF66;         /* Flat solid green */\n  --success-glow: transparent;\n  --success-bg: #0C2014;\n  \n  --warning: #FF8F00;         /* Flat solid orange */\n  --warning-glow: transparent;\n  --warning-bg: #281D10;\n  \n  --error: #FF3366;           /* Flat solid crimson */\n  --error-glow: transparent;\n  --error-bg: #2A1016;\n  \n  --info: #00B0FF;            /* Flat solid blue */\n  --info-bg: #0A1E2C;\n  \n  --text-bright: #FFFFFF;     /* Pure white */\n  --text-normal: #A0A2AD;     /* Gray */\n  --text-muted: #626470;      /* Dark gray */\n  --text-dark: #323440;\n  \n  --radius-lg: 0px;           /* Sharp, flat edges */\n  --radius-md: 0px;\n  --radius-sm: 0px;\n}\n\nbody {\n  background: var(--bg-darkest) !important;\n  background-image: none !important;\n  font-family: 'JetBrains Mono', monospace !important;\n  color: var(--text-normal) !important;\n}\n\nh1, h2, h3, h4, h5, h6, select, button, input {\n  font-family: 'JetBrains Mono', monospace !important;\n  text-shadow: none !important;\n  background-image: none !important;\n}\n\n/* Restructure into clean 3-pane IDE layout */\n.app-container {\n  display: grid !important;\n  grid-template-columns: 240px 1fr !important;\n  height: 100vh !important;\n  overflow: hidden !important;\n  background: var(--bg-darkest) !important;\n}\n\n.sidebar {\n  border-right: 1px solid var(--border-hud) !important;\n  padding: 16px !important;\n  background: var(--bg-darker) !important;\n}\n\n.brand {\n  border-bottom: 1px solid var(--border-hud) !important;\n  margin-bottom: 16px !important;\n  padding-bottom: 12px !important;\n}\n\n.brand-text h1 {\n  background: none !important;\n  -webkit-background-clip: unset !important;\n  -webkit-text-fill-color: unset !important;\n  color: var(--text-bright) !important;\n  font-weight: 700 !important;\n  font-size: 16px !important;\n}\n\n.logo-icon {\n  animation: none !important;\n  filter: none !important;\n}\n\n.repo-item {\n  border: 1px solid var(--border-hud) !important;\n  border-radius: var(--radius-md) !important;\n  margin-bottom: 4px !important;\n  padding: 8px 12px !important;\n  background: var(--bg-darker) !important;\n}\n\n.repo-item:hover, .repo-item.active {\n  background: var(--bg-hud) !important;\n  border-color: var(--primary) !important;\n  transform: none !important;\n  box-shadow: none !important;\n}\n\n.dashboard-main {\n  display: flex !important;\n  flex-direction: column !important;\n  height: 100vh !important;\n  padding: 0 !important;\n  overflow: hidden !important;\n  background: var(--bg-darkest) !important;\n}\n\n.hud-header {\n  min-height: 64px !important;\n  height: auto !important;\n  padding: 12px 24px !important;\n  margin-bottom: 0 !important;\n  border-bottom: 1px solid var(--border-hud) !important;\n  background: var(--bg-darker) !important;\n  display: flex !important;\n  flex-wrap: wrap !important;\n  align-items: center !important;\n  justify-content: space-between !important;\n  gap: 16px !important;\n  flex-shrink: 0 !important;\n}\n\n.hud-title-area {\n  display: flex !important;\n  flex-direction: row !important;\n  align-items: center !important;\n  gap: 12px !important;\n  min-width: 0 !important;\n  flex-shrink: 1 !important;\n}\n\n.hud-tag {\n  margin: 0 !important;\n  flex-shrink: 0 !important;\n  align-self: center !important;\n}\n\n.hud-title-area h2 {\n  font-size: 16px !important;\n  font-weight: 600 !important;\n  margin: 0 !important;\n  white-space: nowrap !important;\n  overflow: hidden !important;\n  text-overflow: ellipsis !important;\n  min-width: 0 !important;\n  flex-shrink: 1 !important;\n  align-self: center !important;\n}\n\n#pro-badge {\n  margin: 0 !important;\n  flex-shrink: 0 !important;\n  align-self: center !important;\n  border-radius: 0px !important;\n}\n\n.hud-actions {\n  display: flex !important;\n  flex-wrap: wrap !important;\n  align-items: center !important;\n  gap: 12px !important;\n}\n\n.control-group {\n  display: flex !important;\n  flex-direction: row !important;\n  align-items: center !important;\n  gap: 8px !important;\n}\n\n.control-group label {\n  margin: 0 !important;\n  white-space: nowrap !important;\n}\n\n.btn {\n  border-radius: 0px !important;\n  border: 1px solid var(--border-hud) !important;\n  background: var(--bg-darker) !important;\n  color: var(--text-bright) !important;\n  box-shadow: none !important;\n  font-size: 12px !important;\n  padding: 6px 12px !important;\n  text-transform: uppercase !important;\n}\n\n.btn:hover {\n  background: var(--bg-hud) !important;\n  border-color: var(--border-hover) !important;\n  transform: none !important;\n  box-shadow: none !important;\n}\n\n.btn-action {\n  border-color: var(--primary) !important;\n}\n\n.btn-action:hover {\n  background: var(--primary-bg) !important;\n  border-color: var(--primary-hover) !important;\n}\n\n.btn-pro {\n  border-color: var(--accent-pro) !important;\n  background: var(--accent-pro-bg) !important;\n  color: var(--accent-pro) !important;\n}\n\n.btn-pro:hover {\n  background: var(--accent-pro) !important;\n  color: var(--bg-darkest) !important;\n}\n\n.pr-select {\n  border-radius: 0px !important;\n  border: 1px solid var(--border-hud) !important;\n  background: var(--bg-darkest) !important;\n  color: var(--text-bright) !important;\n  padding: 6px 10px !important;\n  font-size: 12px !important;\n}\n\n/* Two-pane content grid layout */\n.dashboard-panes-wrapper {\n  display: grid !important;\n  grid-template-columns: 420px 1fr !important;\n  flex-grow: 1 !important;\n  height: auto !important;\n  overflow: hidden !important;\n}\n\n.dashboard-pane {\n  overflow-y: auto !important;\n  padding: 20px !important;\n  display: flex !important;\n  flex-direction: column !important;\n  gap: 20px !important;\n}\n\n.pane-left {\n  border-right: 1px solid var(--border-hud) !important;\n  background: var(--bg-darker) !important;\n}\n\n.pane-right {\n  background: var(--bg-darkest) !important;\n}\n\n.hud-card {\n  background: var(--bg-hud) !important;\n  border: 1px solid var(--border-hud) !important;\n  border-radius: 0px !important;\n  padding: 16px !important;\n  box-shadow: none !important;\n  background-image: none !important;\n}\n\n.score-hud-card {\n  display: flex !important;\n  align-items: center !important;\n  justify-content: space-between !important;\n  padding: 16px 20px !important;\n}\n\n.score-hud-card h3 {\n  font-size: 13px !important;\n  text-transform: uppercase !important;\n  color: var(--text-muted) !important;\n  margin: 0 !important;\n}\n\n.score-display-flat {\n  font-size: 28px !important;\n  font-weight: 700 !important;\n  color: var(--primary) !important;\n  font-family: 'JetBrains Mono', monospace !important;\n  display: flex !important;\n  align-items: baseline !important;\n}\n\n.score-denom {\n  font-size: 14px !important;\n  color: var(--text-muted) !important;\n  margin-left: 2px !important;\n}\n\n.score-status-badge {\n  border-radius: 0px !important;\n  box-shadow: none !important;\n  font-size: 10px !important;\n  padding: 4px 8px !important;\n  letter-spacing: 0.05em !important;\n}\n\n.summary-hud-card {\n  background: var(--bg-hud) !important;\n}\n\n.summary-hud-card h3 {\n  font-size: 12px !important;\n  text-transform: uppercase !important;\n  color: var(--text-muted) !important;\n  margin-bottom: 8px !important;\n  border-bottom: 1px solid var(--border-hud) !important;\n  padding-bottom: 6px !important;\n}\n\n.summary-details h4 {\n  font-size: 14px !important;\n  color: var(--text-bright) !important;\n  margin-bottom: 8px !important;\n}\n\n.summary-content-text {\n  font-size: 12px !important;\n  color: var(--text-normal) !important;\n  line-height: 1.6 !important;\n}\n\n.hud-section h3 {\n  font-size: 12px !important;\n  text-transform: uppercase !important;\n  color: var(--text-muted) !important;\n  margin-bottom: 12px !important;\n  border-bottom: 1px solid var(--border-hud) !important;\n  padding-bottom: 6px !important;\n}\n\n/* Dimensions Postures list */\n.dimensions-grid {\n  display: flex !important;\n  flex-direction: column !important;\n  gap: 10px !important;\n}\n\n.dimension-card {\n  background: var(--bg-darkest) !important;\n  border: 1px solid var(--border-hud) !important;\n  padding: 10px 12px !important;\n  border-radius: 0px !important;\n  box-shadow: none !important;\n}\n\n.dim-header {\n  display: flex !important;\n  justify-content: space-between !important;\n  align-items: center !important;\n  font-size: 12px !important;\n  font-weight: 500 !important;\n}\n\n.dim-name {\n  color: var(--text-bright) !important;\n  text-transform: uppercase !important;\n}\n\n.dim-bar-wrapper {\n  background: var(--bg-hud) !important;\n  height: 4px !important;\n  border-radius: 0px !important;\n  margin: 6px 0 !important;\n  border: none !important;\n}\n\n.dim-bar {\n  height: 100% !important;\n  border-radius: 0px !important;\n  transition: width var(--t-smooth) !important;\n}\n\n.dim-notes {\n  margin-top: 4px !important;\n  font-size: 10px !important;\n}\n\n.note-hit {\n  color: var(--warning) !important;\n}\n\n.note-none {\n  color: var(--text-muted) !important;\n}\n\n/* Right Pane: LLM Thought process terminal styled console */\n.thought-hud-card {\n  padding: 0 !important;\n  display: flex !important;\n  flex-direction: column !important;\n}\n\n.thought-hud-card h3 {\n  font-size: 12px !important;\n  text-transform: uppercase !important;\n  color: var(--text-muted) !important;\n  padding: 12px 16px !important;\n  margin: 0 !important;\n  border-bottom: 1px solid var(--border-hud) !important;\n  background: var(--bg-darker) !important;\n}\n\n.thought-process-console {\n  background: var(--bg-terminal) !important;\n  padding: 16px !important;\n  max-height: 320px !important;\n  min-height: 120px !important;\n  overflow-y: auto !important;\n  border-radius: 0px !important;\n  border: none !important;\n}\n\n.thought-process-content {\n  font-family: 'JetBrains Mono', monospace !important;\n  font-size: 12px !important;\n  line-height: 1.6 !important;\n  color: #00FF66 !important; /* Stark terminal green */\n  white-space: pre-wrap !important;\n}\n\n/* Risks / Warnings list */\n.risks-list {\n  display: flex !important;\n  flex-direction: column !important;\n  gap: 8px !important;\n}\n\n.risk-item {\n  background: var(--bg-hud) !important;\n  border: 1px solid var(--border-hud) !important;\n  border-radius: 0px !important;\n  padding: 12px !important;\n  box-shadow: none !important;\n  display: flex !important;\n  flex-direction: column !important;\n  gap: 6px !important;\n}\n\n.risk-item:hover {\n  border-color: var(--border-hover) !important;\n  transform: none !important;\n}\n\n.risk-header {\n  display: flex !important;\n  align-items: center !important;\n  justify-content: space-between !important;\n  font-size: 12px !important;\n  font-weight: 600 !important;\n}\n\n.risk-title-container {\n  display: flex !important;\n  align-items: center !important;\n  gap: 8px !important;\n}\n\n.risk-badge {\n  font-size: 9px !important;\n  padding: 2px 6px !important;\n  border-radius: 0px !important;\n  text-transform: uppercase !important;\n}\n\n.risk-badge.critical {\n  background: var(--error-bg) !important;\n  color: var(--error) !important;\n  border: 1px solid var(--error) !important;\n}\n\n.risk-badge.warning {\n  background: var(--warning-bg) !important;\n  color: var(--warning) !important;\n  border: 1px solid var(--warning) !important;\n}\n\n.risk-badge.info {\n  background: var(--info-bg) !important;\n  color: var(--info) !important;\n  border: 1px solid var(--info) !important;\n}\n\n.risk-loc {\n  font-size: 10px !important